generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model categorias {
  id_categoria        Int         @id @default(autoincrement())
  nombre_categoria    String      @unique @db.VarChar(100)
  descripcion         String?
  estado              Boolean?    @default(true)
  fecha_creacion      DateTime?   @default(now()) @db.Timestamp(6)
  fecha_actualizacion DateTime?   @default(now()) @db.Timestamp(6)
  productos           productos[]
}

model clientes {
  id_cliente          Int       @id @default(autoincrement())
  cedula              String?   @unique @db.VarChar(10)
  nombre_cliente      String    @db.VarChar(150)
  telefono            String?   @db.VarChar(15)
  email               String?   @db.VarChar(100)
  direccion           String?
  estado              Boolean?  @default(true)
  fecha_creacion      DateTime? @default(now()) @db.Timestamp(6)
  fecha_actualizacion DateTime? @default(now()) @db.Timestamp(6)
  ventas              ventas[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model compras {
  id_compra       Int               @id @default(autoincrement())
  numero_compra   String            @unique @db.VarChar(50)
  id_proveedor    Int?
  id_usuario      Int?
  fecha_compra    DateTime?         @default(now()) @db.Timestamp(6)
  total_compra    Decimal           @db.Decimal(10, 2)
  estado          String?           @default("completada") @db.VarChar(20)
  observaciones   String?
  proveedores     proveedores?      @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: NoAction, onUpdate: NoAction)
  usuarios        usuarios?         @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  detalle_compras detalle_compras[]

  @@index([fecha_compra], map: "idx_compras_fecha")
  @@index([id_proveedor], map: "idx_compras_proveedor")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model detalle_compras {
  id_detalle_compra Int        @id @default(autoincrement())
  id_compra         Int?
  id_producto       Int?
  cantidad          Int
  precio_unitario   Decimal    @db.Decimal(10, 2)
  subtotal          Decimal?   @default(dbgenerated("((cantidad)::numeric * precio_unitario)")) @db.Decimal(10, 2)
  compras           compras?   @relation(fields: [id_compra], references: [id_compra], onDelete: Cascade, onUpdate: NoAction)
  productos         productos? @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model detalle_ventas {
  id_detalle_venta Int        @id @default(autoincrement())
  id_venta         Int?
  id_producto      Int?
  cantidad         Int
  precio_unitario  Decimal    @db.Decimal(10, 2)
  subtotal         Decimal?   @default(dbgenerated("((cantidad)::numeric * precio_unitario)")) @db.Decimal(10, 2)
  productos        productos? @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction)
  ventas           ventas?    @relation(fields: [id_venta], references: [id_venta], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model productos {
  id_producto         Int               @id @default(autoincrement())
  codigo_producto     String            @unique @db.VarChar(50)
  nombre_producto     String            @db.VarChar(200)
  descripcion         String?
  id_categoria        Int?
  precio_compra       Decimal           @db.Decimal(10, 2)
  precio_venta        Decimal           @db.Decimal(10, 2)
  stock_actual        Int?              @default(0)
  stock_minimo        Int?              @default(5)
  imagen_url          String?           @db.VarChar(255)
  estado              Boolean?          @default(true)
  fecha_creacion      DateTime?         @default(now()) @db.Timestamp(6)
  fecha_actualizacion DateTime?         @default(now()) @db.Timestamp(6)
  detalle_compras     detalle_compras[]
  detalle_ventas      detalle_ventas[]
  categorias          categorias?       @relation(fields: [id_categoria], references: [id_categoria], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_categoria], map: "idx_productos_categoria")
  @@index([codigo_producto], map: "idx_productos_codigo")
}

model proveedores {
  id_proveedor        Int       @id @default(autoincrement())
  nombre_proveedor    String    @db.VarChar(150)
  ruc                 String?   @unique @db.VarChar(13)
  telefono            String?   @db.VarChar(15)
  email               String?   @db.VarChar(100)
  direccion           String?
  estado              Boolean?  @default(true)
  fecha_creacion      DateTime? @default(now()) @db.Timestamp(6)
  fecha_actualizacion DateTime? @default(now()) @db.Timestamp(6)
  compras             compras[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model usuarios {
  id_usuario     Int       @id @default(autoincrement())
  nombre_usuario String    @db.VarChar(100)
  email          String    @unique @db.VarChar(100)
  password_hash  String    @db.VarChar(255)
  rol            String?   @default("administrador") @db.VarChar(20)
  estado         Boolean?  @default(true)
  fecha_creacion DateTime? @default(now()) @db.Timestamp(6)
  ultimo_acceso  DateTime? @db.Timestamp(6)
  compras        compras[]
  ventas         ventas[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ventas {
  id_venta       Int              @id @default(autoincrement())
  numero_venta   String           @unique @db.VarChar(50)
  id_cliente     Int?
  id_usuario     Int?
  fecha_venta    DateTime?        @default(now()) @db.Timestamp(6)
  subtotal       Decimal          @db.Decimal(10, 2)
  descuento      Decimal?         @default(0) @db.Decimal(10, 2)
  total_venta    Decimal          @db.Decimal(10, 2)
  metodo_pago    String?          @default("efectivo") @db.VarChar(20)
  estado         String?          @default("completada") @db.VarChar(20)
  observaciones  String?
  detalle_ventas detalle_ventas[]
  clientes       clientes?        @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction)
  usuarios       usuarios?        @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_cliente], map: "idx_ventas_cliente")
  @@index([fecha_venta], map: "idx_ventas_fecha")
}
